{
  "manifest_version": 3,
  "name": "iNaturalist Sound Classifier",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "unlimitedStorage",
    "storage"
  ],
  "host_permissions": [
    "https://api.inaturalist.org/*",
    "https://static.inaturalist.org/*",
    "https://huggingface.co/*",
    "https://*.huggingface.co/*",
    "https://*.hf.co/*",
    "https://zenodo.org/*",
    "https://api.gbif.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.inaturalist.org/observations/*"],
      "js": [
        "config.js",
        "ui.js",
        "audio.js",
        "model.js",
        "content.js",
        "geo.js"
      ],
      "css" : ["styles/inaturalist.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "onnx/*",
        "inference-worker.js",
        "model_zoo/*.json",
        "language/*.json",
        "styles/*.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}